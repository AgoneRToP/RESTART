<div class="container">
    <header>
        <h1>{{title}}</h1>
    </header>

    <div class="posts-grid">
        {{#each posts}}
        <div class="post-card">
            <h3>{{this.title}}</h3>
            <p>{{this.content}}</p>
            
            <div class="post-footer">
                <span>📅 {{this.createdAt}}</span>
                <span class="views-tag">👁 {{this.viewsCount}}</span>
            </div>
        </div>
        {{else}}
        <p>No posts yet...</p>
        {{/each}}
    </div>
</div>